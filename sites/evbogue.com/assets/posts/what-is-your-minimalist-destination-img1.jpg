,["up","","Buzz","Everett Bogue","I launched an evolving digital book on the day the physical encyclopedia died. Coincidence (or fate?!)",1331706116807,"https://web.archive.org/web/20120322202814/http://www.google.com/favicon.ico",[[,"Conni Biesalski","Fate! Loving the book, Ev. Hope to get together for an interview soon?",1331823679112,"z13gvzrbowqfsjz1n23dslbqpvumyjjhr04#1331823679112382",,"102590617779936302022","z13gvzrbowqfsjz1n23dslbqpvumyjjhr04",0,1,"./102590617779936302022",1,,,0,[,,,,,,,,,,,,[]
