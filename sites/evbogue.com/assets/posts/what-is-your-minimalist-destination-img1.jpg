,"//web.archive.org/web/20120322202814/https://maps-api-ssl.google.com/maps/api/staticmap?size\u003d195x150\u0026sensor\u003dfalse\u0026client\u003dgoogle-profiles\u0026language\u003den\u0026markers\u003dsize:small%7Ccolor:blue%7C37.77493,-122.419416\u0026markers\u003dsize:small%7Ccolor:green%7C20.622018,-105.228457%7C47.60621,-122.332071%7C40.014986,-105.270546%7C41.878114,-87.629798%7C40.714353,-74.005973%7C45.523452,-122.676207%7C41.878114,-87.629798%7C21.033333,105.85\u0026signature\u003dyaHOgmFt13WAXxvfdF6xm9yYJjY%3D",[[]
