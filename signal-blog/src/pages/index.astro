---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [hero, ...rest] = posts;
const sideStories = rest.slice(0, 3);
const gridPosts = rest.slice(3, 6);
const morePosts = rest.slice(6, 9);
const featured = posts.find(p => p.data.tag === 'Essay') ?? null;

function formatDate(d) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function readTime(body) {
  return Math.max(1, Math.round(body.split(/\s+/).length / 200));
}
---
<Base>
  {hero && (
    <section class="hero">
      <a href={`/posts/${hero.id}`} class="hero-main" style="text-decoration:none">
        <span class="tag">{hero.data.tag}</span>
        <div class="hero-title">{hero.data.title}</div>
        <p class="hero-dek">{hero.data.description}</p>
        <div class="hero-meta">
          <span class="author">{hero.data.author}</span>
          <span class="dot">·</span>
          <span>{formatDate(hero.data.date)}</span>
          <span class="dot">·</span>
          <span>{readTime(hero.body)} min read</span>
        </div>
      </a>
      <div class="hero-side">
        {sideStories.map(post => (
          <a href={`/posts/${post.id}`} class="side-story">
            <span class="tag">{post.data.tag}</span>
            <div class="side-title">{post.data.title}</div>
            <p class="side-dek">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {gridPosts.length > 0 && (
    <>
      <div class="section-header">
        <span class="section-label">Latest</span>
        <div class="section-rule"></div>
      </div>
      <div class="article-grid">
        {gridPosts.map(post => (
          <a href={`/posts/${post.id}`} class="card">
            <div class="card-img"><div class="card-img-inner">{post.data.tag}</div></div>
            <span class="tag">{post.data.tag}</span>
            <div class="card-title">{post.data.title}</div>
            <p class="card-dek">{post.data.description}</p>
            <div class="card-meta">
              <span>{formatDate(post.data.date)}</span><span>·</span>
              <span>{readTime(post.body)} min</span>
            </div>
          </a>
        ))}
      </div>
    </>
  )}

  {featured && featured.slug !== hero?.slug && (
    <div class="essay-band">
      <div class="essay-inner">
        <div class="essay-eyebrow">Featured Essay</div>
        <h2 class="essay-title">{featured.data.title}</h2>
        <div class="essay-body"><p>{featured.data.description}</p></div>
        <a href={`/posts/${featured.id}`} class="read-more">Continue Reading</a>
      </div>
    </div>
  )}

  {morePosts.length > 0 && (
    <>
      <div class="section-header">
        <span class="section-label">More Stories</span>
        <div class="section-rule"></div>
      </div>
      <div class="article-grid">
        {morePosts.map(post => (
          <a href={`/posts/${post.id}`} class="card">
            <div class="card-img"><div class="card-img-inner">{post.data.tag}</div></div>
            <span class="tag">{post.data.tag}</span>
            <div class="card-title">{post.data.title}</div>
            <p class="card-dek">{post.data.description}</p>
            <div class="card-meta">
              <span>{formatDate(post.data.date)}</span><span>·</span>
              <span>{readTime(post.body)} min</span>
            </div>
          </a>
        ))}
      </div>
    </>
  )}
</Base>
